# ============================================================
# .env.example  —  copy this to .env and adjust values
#   cp backend/.env.example backend/.env
# ============================================================

# Express server port
PORT=4000

# PostgreSQL connection
DB_USER=postgres
DB_HOST=localhost
DB_PASSWORD=postgres
DB_PORT=5432
DB_NAME=flappy_bird_game

# NOTE: When running through docker-compose, DB_HOST must be "db"
# (the service name), not "localhost". docker-compose.yml already
# sets these values for the backend container.
